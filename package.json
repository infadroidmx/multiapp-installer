{
  "name": "multiapp-installer",
  "private": true,
  "version": "1.0.24",
  "type": "module",
  "description": "Postiz Native Windows Manager",
  "author": "Huezorises LLC",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:start": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "build:win": "npm run build && electron-builder --win dir",
    "dist": "npm run build && electron-builder",
    "dist:release": "npm run build && electron-builder --config.directories.output=dist-release",
    "bump-version": "node scripts/bump-version.js",
    "sign-installer": "powershell -ExecutionPolicy Bypass -File scripts/sign-installer.ps1",
    "build:signed": "npm run bump-version && npm run build && npm run build:win && powershell -ExecutionPolicy Bypass -File scripts/sign-installer.ps1 \"release/installer/Multiapp Installer Setup.exe\""
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "lucide-react": "^0.359.0",
    "node-ssh": "^13.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.huezollc.multiappinstaller",
    "productName": "Multiapp Installer",
    "npmRebuild": false,
    "directories": {
      "output": "release/installer"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "public/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "publisherName": "Huezorises LLC"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Multiapp Installer",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "license": null,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}